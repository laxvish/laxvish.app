// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Lead capture vault model for Laxvish enterprise integration
model Lead {
  id        String   @id @default(cuid())
  name      String   @db.VarChar(255)
  email     String   @db.VarChar(255)
  company   String   @db.VarChar(255)
  useCase   String   @db.Text
  status    String   @default("pending") // pending, contacted, pilot, inactive
  identity  String?  @db.Char(64) // SHA-256 hash for deduplication
  
  // Metadata and timestamps
  source    String   @default("website") // website, api, import, etc.
  metadata  String   @default("{}") @db.Text // JSON string for additional data
  notes     String?  @db.Text
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Indexes for query performance
  @@index([email])
  @@index([company])
  @@index([createdAt])
  @@index([status])
}
